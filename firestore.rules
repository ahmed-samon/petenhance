rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, petId, xp, level, coins, achievements
    //
    // Collection: pets
    // Fields: id, userId, type, name, stats, evolutionStage, level, appearance, lastInteraction
    //
    // Collection: actions
    // Fields: userId, petId, type, timestamp, xpGained
    //
    // Collection: ai_logs
    // Fields: userId, petId, message, response, mood, timestamp
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidPet(data) {
      return data.keys().hasAll(['userId', 'type', 'name', 'stats']) &&
             data.userId == request.auth.uid &&
             data.type in ['cat', 'dog', 'dragon', 'alien', 'slime'] &&
             data.name is string && data.name.size() > 0 && data.name.size() < 30;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /pets/{petId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidPet(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidPet(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /actions/{actionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /ai_logs/{logId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
